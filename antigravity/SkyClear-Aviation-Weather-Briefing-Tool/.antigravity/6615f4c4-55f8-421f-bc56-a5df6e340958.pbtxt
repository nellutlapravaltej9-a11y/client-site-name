      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQG2d9vJBpVpLyq1BOL-8hrKJHYMr3JNFSA9t-513p0M3pWsGJmAgpQp75Bupa0LNIdLHne-54MIAI2uyXrdN_q9UtHBh1AliFLkDerLsgDIRLFjuWVNEGHCwZVUU4w_0bNjP3STlGJ07fmTEP0QSgWkWyM7vcw62u3Dqlq0KG1M9mnY"
