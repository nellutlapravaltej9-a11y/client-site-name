        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Check temp/dewpoint (e.g. 20/15 or M02/M05)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (/^(M?\\d{2})\\/(M?\\d{2})?$/.test(tok)) continue;"
