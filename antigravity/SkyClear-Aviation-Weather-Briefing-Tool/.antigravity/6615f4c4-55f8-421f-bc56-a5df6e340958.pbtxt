      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGi4vRfRv56-D0SHXKujZx97OaTma6JQh4KJC2JTKMTx9csSx7YbG80qSeKH2Lgu__aJWLCS_wjl7p1vGlx9I7w0x8BPv9xx4huyrSAhSE55rcRx6X8JdAjso7lAJt48P7IPrubt7sXBL7N3X14lzYpqCSVJLhaYukCEsu8NJrVBKRtc5dW-PEyDr8c5gSfnrPc4utQiX3xSRxvyLXxv_J9I065"
