    web_documents {
      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFVGsUkX0O2GW97-6VdvTbSB3oYxgjuHRmD32YDNm3fZVAMZh8dpBuJ0xG3UWljQLw_tB5W9FeS60h6wQyw-TNgd7xHkDz8DvusOTC37L9fIjhyDMRHcpmlP3vkOO35JeDxrkWkevh3mBF2phJyQDYZRkKZlFFNycLcLmIq2Rz8Xo_R28NvIg4S2kOjTIqpQuvt7SCEBOoXPELqx-uWnIxbSImvcqyAmt6uCu4bp8OcMTJ84mWKz8zyBRuvJUFq-t7dMeo="
