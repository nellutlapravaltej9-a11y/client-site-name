    web_documents {
      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHDcICBVuswE7R-aa7fh_GRRx-G5uFF1Y6uvyX6NoJtWwLu7vRCLP0njn6k_pZYwaR43s2KeusPSAdqZAYxcGYNhHA9Ib7yT9ssEDyUum1RRxPKCNal8xAqTPog0CAb1FpTJ7zDKEpItCpsJ2M7R38e0lSd_EBAYWmUu44QKToE9K9BCYz-gQMUUaupd9eqrG0l_3ZZUzVZaO9NGCg55_tEjQM-p_Tu9BNz-vSQ14jwgg=="
