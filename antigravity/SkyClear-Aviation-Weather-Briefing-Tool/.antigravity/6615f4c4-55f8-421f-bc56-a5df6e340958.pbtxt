      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHn4r1D7eMYygQwHktnEuYvqqpq4HD3BoshBb6ug_7TGBJqi804MM2ybn6AqG3smZsegozKbk8AemNZdiclPUdkhXZEn_PJhWSaAmfBVBFvDQBEvgpF9zLCP8Bm-V4sClKQQR1oOkehLL6c4aZF6nZw2mjFwgJLpZfA_ZTGgqn4IO7d6kIwQI2AvX580RM5irDeGblO8fPW5LZE-ibz"
