        }
        lines {
          text: "              <h3 className=\"font-display text-lg font-bold text-slate-100 flex items-center gap-2\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                <BookOpen className=\"w-5 h-5 text-[#38BDF8]\" />"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                Pilot Reference Card"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </h3>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <p className=\"text-xs font-mono text-slate-500 uppercase tracking-wider mt-0.5\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                Educational Airspace Notes"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </p>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            </div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            {/* Paragraph 1: What is a METAR */}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            <div className=\"space-y-2 border-b border-[#1E293B] pb-4\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <h4 className=\"text-xs font-mono font-bold text-[#38BDF8] uppercase tracking-wide\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                What is a METAR?"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </h4>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <p className=\"text-slate-300 text-xs leading-relaxed\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                A METAR (Meteorological Aerodrome Report) is an aviation weather report issued hourly. It outlines real-time winds, visibility, weather systems, and clouds. It serves as the primary observation source for pilots during pre-flight."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </p>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            </div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            {/* Paragraph 2: Fog Formation Rule of Thumb */}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            <div className=\"space-y-2 border-b border-[#1E293B] pb-4\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <h4 className=\"text-xs font-mono font-bold text-[#38BDF8] uppercase tracking-wide\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                Dewpoint Spread &amp; Fog"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </h4>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <p className=\"text-slate-300 text-xs leading-relaxed\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                When the temperature and dewpoint spread is within 3 degrees Celsius (5.4 degrees Fahrenheit), the relative humidity reaches near-saturation. Under calm or light winds, there is a high probability of fog or low-ceiling stratus cloud formation. Avoid flight patterns without instrument ratings."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </p>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            </div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            {/* Paragraph 3: VFR minimums reminder */}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            <div className=\"space-y-2 border-b border-[#1E293B] pb-4\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <h4 className=\"text-xs font-mono font-bold text-[#38BDF8] uppercase tracking-wide\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                VFR Flight Minimums"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </h4>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <p className=\"text-slate-300 text-xs leading-relaxed\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                Under standard Class E airspace regulations, basic visual flight rules (VFR) require at least 3 statute miles of flight visibility and a cloud ceiling of no less than 1,000 feet above the surface (AGL). Remember that safe pilots maintain buffers above regulatory minimums."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </p>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            </div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            {/* Paragraph 4: AIP placeholder links */}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            <div className=\"space-y-2\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <h4 className=\"text-xs font-mono font-bold text-[#38BDF8] uppercase tracking-wide\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                Aviation Publications (AIP)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </h4>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <p className=\"text-slate-300 text-xs leading-relaxed\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                For complete runway geometry, navigation frequencies, and localized noise abatement charts, verify the official Aeronautical Information Publication (AIP)."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </p>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <div className=\"pt-2\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                <a "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  href=\"https://www.faa.gov/air_traffic/publications/atpubs/aip_html/index.html\" "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  target=\"_blank\" "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  rel=\"noreferrer\" "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  className=\"inline-flex items-center gap-1 text-xs text-[#38BDF8] hover:underline font-mono\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                >"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  FAA AIP Directory &rarr;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                </a>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            </div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          </div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        </div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      </div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
