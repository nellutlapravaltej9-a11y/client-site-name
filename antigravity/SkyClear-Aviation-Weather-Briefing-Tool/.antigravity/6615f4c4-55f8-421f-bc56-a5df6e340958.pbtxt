  file_change {
    absolute_path_uri: "file:///src/components/HomeView.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { Search, Plane, AlertCircle } from \'lucide-react\';\n\ninterface HomeViewProps {\n  onSearch: (icao: string) => void;\n  isLoading: boolean;\n  error: string | null;\n}\n\nexport default function HomeView({ onSearch, isLoading, error }: HomeViewProps) {\n  const [icao, setIcao] = useState(\'\');\n\n  const handleSubmit = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (icao.trim()) {\n      onSearch(icao.trim());\n    }\n  };\n\n  const handleQuickAccess = (code: string) => {\n    setIcao(code);\n    onSearch(code);\n  };\n\n  const popularAirports = [\n    { code: \'WSSS\', name: \'Singapore Changi\' },\n    { code: \'EGLL\', name: \'London Heathrow\' },\n    { code: \'KJFK\', name: \'New York JFK\' },\n    { code: \'OMDB\', name: \'Dubai Intl\' }\n  ];\n\n  return (\n    <div className=\"flex-1 flex flex-col justify-between max-w-4xl mx-auto px-4 py-12 md:py-24\" id=\"home-view-container\">\n      {/* Hero Section */}\n      <div className=\"flex-1 flex flex-col items-center justify-center text-center my-auto\">\n        <div className=\"inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[#38BDF8]/20 bg-[#38BDF8]/5 text-[#38BDF8] text-xs font-mono mb-8 tracking-wider uppercase\">\n          <Plane className=\"w-3.5 h-3.5 rotate-45\" />\n          Aviation Weather Service\n        </div>\n\n        <h1 className=\"font-display text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-white mb-4\">\n          SKY<span className=\"text-[#38BDF8]\">CLEAR</span>\n        </h1>\n        \n        <p className=\"text-slate-400 text-lg sm:text-xl max-w-2xl mb-12 leading-relaxed\">\n          Plain English weather for pilots. No decoder ring needed.\n        </p>\n\n        {/* Search Bar Form */}\n        <form onSubmit={handleSubmit} className=\"w-full max-w-xl mb-6\" id=\"search-form\">\n          <div className=\"relative flex flex-col sm:flex-row gap-3\">\n            <div className=\"relative flex-1\">\n              <div className=\"absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none\">\n                <Search className=\"h-5 w-5 text-slate-500\" />\n              </div>\n              <input\n                type=\"text\"\n                value={icao}\n                onChange={(e) => setIcao(e.target.value.toUpperCase())}\n                placeholder=\"Enter Airport ICAO Code (e.g., KJFK)\"\n                maxLength={4}\n                autoFocus\n                disabled={isLoading}\n                className=\"block w-full pl-11 pr-4 py-4 bg-[#0F172A] border border-[#1E293B] rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-[#38BDF8] focus:ring-1 focus:ring-[#38BDF8] text-lg font-mono tracking-widest disabled:opacity-50 transition-all uppercase\"\n                id=\"icao-search-input\"\n              />\n            </div>\n            <button\n              type=\"submit\"\n              disabled={isLoading || !icao.trim()}\n              className=\"px-8 py-4 bg-[#38BDF8] hover:bg-[#0EA5E9] disabled:bg-[#38BDF8]/40 disabled:text-slate-400 disabled:cursor-not-allowed text-[#0A0F1E] font-display font-semibold text-lg rounded-xl shadow-lg shadow-[#38BDF8]/10 transition-all flex items-center justify-center gap-2 cursor-pointer\"\n              id=\"get-briefing-btn\"\n            >\n              {isLoading ? \'Decoding...\' : \'Get Briefing\'}\n            </button>\n          </div>\n        </form>\n\n        {/* Error State */}\n        {error && (\n          <div className=\"w-full max-w-xl mb-8 p-4 rounded-xl border border-red-500/20 bg-red-500/10 text-red-400 text-sm flex items-center gap-3 text-left\">\n            <AlertCircle className=\"w-5 h-5 flex-shrink-0\" />\n            <div>\n              <p className=\"font-semibold\">Briefing Error</p>\n              <p className=\"text-slate-300 text-xs mt-0.5\">{error}</p>\n            </div>\n          </div>\n        )}\n\n        {/* Quick Access Buttons */}\n        <div className=\"w-full max-w-xl text-left sm:text-center\">\n          <p className=\"text-xs font-mono uppercase tracking-wider text-slate-500 mb-3\">\n            Quick-Access Pilot Hubs\n          </p>\n          <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-3\">\n            {popularAirports.map((airport) => (\n              <button\n                key={airport.code}\n                type=\"button\"\n                onClick={() => handleQuickAccess(airport.code)}\n                disabled={isLoading}\n                className=\"px-4 py-3 bg-[#0F172A]/50 hover:bg-[#1E293B]/70 border border-[#1E293B] hover:border-[#38BDF8]/30 rounded-xl transition-all text-left flex flex-col justify-between group cursor-pointer disabled:opacity-50\"\n                id={`quick-${airport.code}-btn`}\n              >\n                <span className=\"font-mono font-bold text-white group-hover:text-[#38BDF8] transition-colors\">\n                  {airport.code}\n                </span>\n                <span className=\"text-[10px] text-slate-500 truncate mt-1\">\n                  {airport.name}\n                </span>\n              </button>\n            ))}\n          </div>\n        </div>\n      </div>\n\n      {/* Footer Section */}\n      <footer className=\"mt-16 pt-8 border-t border-[#1E293B]/50 text-center text-slate-500 text-xs font-mono\">\n        <p>\n          Built by <span className=\"text-slate-400\">Nellutla Pravaltej</span> \342\200\224 Student Pilot &amp; Aerospace Engineering Applicant\n        </p>\n      </footer>\n    </div>\n  );\n}\n"
    }
