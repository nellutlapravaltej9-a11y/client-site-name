          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (tok === \'RMK\' || tokens.indexOf(tok) >= tokens.indexOf(\'RMK\') && tokens.indexOf(\'RMK\') !== -1) continue;"
