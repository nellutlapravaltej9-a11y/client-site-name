          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (tok.endsWith(\'KT\') || tok.includes(\'MPS\')) continue;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (tok.startsWith(\'A\') && /^\\d{4}$/.test(tok.substring(1))) continue;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (tok.startsWith(\'Q\') && /^\\d{4}$/.test(tok.substring(1))) continue;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (/^\\d{3}V\\d{3}$/.test(tok)) continue; // variable wind range e.g. 200V260"
