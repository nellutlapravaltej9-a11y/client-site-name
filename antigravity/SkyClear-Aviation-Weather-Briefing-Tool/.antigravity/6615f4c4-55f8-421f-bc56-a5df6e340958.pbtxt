    web_documents {
      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQG-EVE-oJFLG4JsupSSjW--9Dv1SHX1_9rghqW8Ti1KvEZWqGU21TJpKQ5FVPpG5JyvaEdTT0A-snvAWKVheAoamfE1hZ1Vm261QyVI9Ggj_Z_JplWoSRb-EKxx56-j4t4cnNy6tRk="
      title: "github.com"
