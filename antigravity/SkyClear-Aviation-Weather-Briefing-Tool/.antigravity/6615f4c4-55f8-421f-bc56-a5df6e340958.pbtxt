  file_change {
    absolute_path_uri: "file:///src/components/BriefingView.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React from \'react\';\nimport { \n  RefreshCw, Wind, Eye, Cloud, HelpCircle, Thermometer, Gauge, Clock, \n  BookOpen, AlertTriangle, ChevronRight, Activity, TrendingUp, Info\n} from \'lucide-react\';\nimport { BriefingData, TAFPeriod } from \'../utils/aviationTypes\';\nimport { \n  ResponsiveContainer, AreaChart, Area, XAxis, YAxis, Tooltip, CartesianGrid, Legend, LineChart, Line \n} from \'recharts\';\n\ninterface BriefingViewProps {\n  briefingData: BriefingData;\n  onRefresh: () => void;\n  isRefreshing: boolean;\n  onBackToSearch: () => void;\n}\n\nexport default function BriefingView({ briefingData, onRefresh, isRefreshing, onBackToSearch }: BriefingViewProps) {\n  const { metar, taf, timestamp } = briefingData;\n\n  // Compile trend chart data from TAF periods\n  const hasTrendData = taf && taf.periods && taf.periods.length > 0;\n  \n  const trendChartData = hasTrendData \n    ? taf.periods.map((p, idx) => {\n        // Parse time display string for chart axis (e.g. \"Day 25 @ 12:00 UTC\" -> \"D25 12Z\")\n        let timeLabel = `P${idx + 1}`;\n        if (p.timeStart) {\n          const match = p.timeStart.match(/Day (\\d+) @ (\\d{2}):(\\d{2})/);\n          if (match) {\n            timeLabel = `${match[1]}/${match[2]}Z`;\n          } else {\n            timeLabel = p.timeStart.replace(\'Day \', \'\').replace(\' UTC\', \'\');\n          }\n        }\n\n        // Handle case where wind is variable or not defined\n        const speed = p.wind ? p.wind.speedKt : 0;\n        const gusts = p.wind ? (p.wind.gustsKt || speed) : 0;\n        const vis = p.visibility ? p.visibility.distanceSm : 10;\n\n        return {\n          name: timeLabel,\n          periodType: p.type,\n          \'Wind Speed\': speed,\n          \'Wind Gusts\': gusts,\n          \'Visibility (SM)\': vis,\n          category: p.flightCategory.code\n        };\n      })\n    : [];\n\n  return (\n    <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8\" id=\"briefing-view-container\">\n      \n      {/* 1. Briefing Header Panel */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-[#1E293B] pb-6\">\n        <div>\n          <button \n            onClick={onBackToSearch}\n            className=\"text-slate-400 hover:text-[#38BDF8] text-xs font-mono uppercase tracking-wider mb-2 flex items-center gap-1 cursor-pointer focus:outline-none\"\n            id=\"back-to-search-btn\"\n          >\n            &larr; Back to Search\n          </button>\n          <div className=\"flex items-center gap-4\">\n            <h2 className=\"font-display text-3xl font-bold tracking-tight text-white uppercase\">\n              Station {metar.icao}\n            </h2>\n            <div className=\"flex flex-wrap gap-2\">\n              {/* Flight Category Badge */}\n              <span className={`px-3 py-1 rounded-full text-xs font-mono font-bold border ${metar.flightCategory.bgClass} ${metar.flightCategory.colorClass} ${metar.flightCategory.borderClass}`}>\n                {metar.flightCategory.code}\n              </span>\n              \n              {/* Stale Weather Warning */}\n              {metar.time.isStale && (\n                <span className=\"px-3 py-1 rounded-full text-xs font-mono font-bold border bg-[#F59E0B]/10 text-[#F59E0B] border-[#F59E0B]/30 flex items-center gap-1.5 animate-pulse\">\n                  <AlertTriangle className=\"w-3.5 h-3.5\" />\n                  Stale Data\n                </span>\n              )}\n            </div>\n          </div>\n          <p className=\"text-xs font-mono text-slate-500 mt-1\">\n            Briefing generated at {timestamp} Local Time\n          </p>\n        </div>\n\n        <div className=\"flex items-center gap-3\">\n          <button\n            onClick={onRefresh}\n            disabled={isRefreshing}\n            className=\"px-4 py-2 bg-[#1E293B] hover:bg-[#38BDF8]/10 text-slate-300 hover:text-[#38BDF8] border border-[#1E293B] hover:border-[#38BDF8]/30 rounded-xl text-sm font-semibold transition-all flex items-center gap-2 cursor-pointer disabled:opacity-50\"\n            id=\"refresh-briefing-btn\"\n          >\n            <RefreshCw className={`w-4 h-4 ${isRefreshing ? \'animate-spin\' : \'\'}`} />\n            {isRefreshing ? \'Refreshing...\' : \'Refresh Live Data\'}\n          </button>\n        </div>\n      </div>\n\n      {/* Raw Strings Display Panel */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n        {/* METAR Code Block */}\n        <div className=\"bg-[#0F172A] border border-[#1E293B] rounded-2xl p-5 shadow-lg\">\n          <div className=\"flex justify-between items-center mb-3\">\n            <span className=\"text-xs font-mono uppercase tracking-wider text-slate-500\">Raw METAR Report</span>\n            <span className=\"text-[10px] font-mono text-slate-400\">Current Observation</span>\n          </div>\n          <p className=\"font-mono text-sm leading-relaxed text-slate-200 select-all tracking-wide bg-[#0A0F1E] p-3 rounded-lg border border-[#1E293B]\">\n            {metar.raw}\n          </p>\n        </div>\n\n        {/* TAF Code Block */}\n        <div className=\"bg-[#0F172A] border border-[#1E293B] rounded-2xl p-5 shadow-lg\">\n          <div className=\"flex justify-between items-center mb-3\">\n            <span className=\"text-xs font-mono uppercase tracking-wider text-slate-500\">Raw TAF Forecast</span>\n            <span className=\"text-[10px] font-mono text-slate-400\">Terminal Forecast Horizon</span>\n          </div>\n          {taf ? (\n            <p className=\"font-mono text-sm leading-relaxed text-slate-200 select-all tracking-wide bg-[#0A0F1E] p-3 rounded-lg border border-[#1E293B]\">\n              {taf.raw}\n            </p>\n          ) : (\n            <div className=\"bg-[#0A0F1E] p-3 rounded-lg border border-[#1E293B]/70 h-[74px] flex items-center justify-center\">\n              <span className=\"text-slate-500 font-mono text-xs\">No TAF Forecast available for this station</span>\n            </div>\n          )}\n        </div>\n      </div>\n\n      {/* Section B: Plain English Natural Summary Block */}\n      <div className=\"bg-[#0F172A] border border-[#1E293B] rounded-2xl p-6 shadow-xl relative overflow-hidden\">\n        <div className=\"absolute top-0 left-0 w-1 h-full bg-[#38BDF8]\"></div>\n        <h3 className=\"text-xs font-mono uppercase tracking-wider text-[#38BDF8] mb-2 font-semibold\">\n          Plain English Flight Briefing Summary\n        </h3>\n        <p className=\"text-slate-200 leading-relaxed font-sans text-base\">\n          {metar.summary}\n        </p>\n      </div>\n\n      {/* Primary Cockpit Briefing Grid (METAR Grid Left + Sidebar Right) */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-8\">\n        \n        {/* Left 2-Columns: METAR & TAF Decoders */}\n        <div className=\"lg:col-span-2 space-y-8\">\n          \n          {/* Section A \342\200\224 METAR DECODER Cards Grid */}\n          <div>\n            <h3 className=\"font-display text-xl font-bold text-white mb-4 flex items-center gap-2\">\n              <Activity className=\"w-5 h-5 text-[#38BDF8]\" />\n              METAR Element Breakdown\n            </h3>\n            \n            <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n              \n              {/* Card 1: Station & Time */}\n              <div className=\"bg-[#0F172A] border border-[#1E293B] rounded-xl p-5 shadow-md hover:border-[#1E293B]/80 transition-colors flex flex-col justify-between h-[150px]\">\n                <div className=\"flex justify-between items-start\">\n                  <span className=\"text-xs font-mono uppercase tracking-wider text-slate-500\">Station &amp; Time</span>\n                  <Clock className=\"w-4 h-4 text-[#38BDF8]\" />\n                </div>\n                <div>\n                  <h4 className=\"font-display text-xl font-bold text-white uppercase mt-1\">\n                    {metar.icao} Airport\n                  </h4>\n                  <div className=\"space-y-0.5 mt-2 font-mono text-xs text-slate-400\">\n                    <p>UTC: {metar.time.utcString}</p>\n                    <p>Local: {metar.time.localString}</p>\n                  </div>\n                </div>\n              </div>\n\n              {/* Card 2: Wind */}\n              <div className=\"bg-[#0F172A] border border-[#1E293B] rounded-xl p-5 shadow-md hover:border-[#1E293B]/80 transition-colors flex flex-col justify-between h-[150px]\">\n                <div className=\"flex justify-between items-start\">\n                  <span className=\"text-xs font-mono uppercase tracking-wider text-slate-500\">Wind Vector</span>\n                  <Wind className=\"w-4 h-4 text-[#38BDF8]\" />\n                </div>\n                <div>\n                  <h4 className={`font-display text-2xl font-bold mt-1 ${metar.wind.colorClass}`}>\n                    {metar.wind.isCalm ? \'Calm\' : `${metar.wind.speedKt} KT`}\n                    {metar.wind.gustsKt && <span className=\"text-sm font-normal text-slate-400 ml-2\">G {metar.wind.gustsKt} KT</span>}\n                  </h4>\n                  <p className=\"text-xs text-slate-400 mt-1.5 truncate\">\n                    {metar.wind.directionText}\n                  </p>\n                </div>\n              </div>\n\n              {/* Card 3: Visibility */}\n              <div className=\"bg-[#0F172A] border border-[#1E293B] rounded-xl p-5 shadow-md hover:border-[#1E293B]/80 transition-colors flex flex-col justify-between h-[150px]\">\n                <div className=\"flex justify-between items-start\">\n                  <span className=\"text-xs font-mono uppercase tracking-wider text-slate-500\">Visibility</span>\n                  <Eye className=\"w-4 h-4 text-[#38BDF8]\" />\n                </div>\n                <div>\n                  <h4 className={`font-display text-2xl font-bold mt-1 ${metar.visibility.colorClass}`}>\n                    {metar.visibility.distanceSm} SM\n                    <span className=\"text-xs text-slate-400 font-normal ml-2\">({metar.visibility.distanceKm} KM)</span>\n                  </h4>\n                  <p className=\"text-xs text-slate-400 mt-1.5\">\n                    Range index: <strong className=\"text-white\">{metar.visibility.label}</strong>\n                  </p>\n                </div>\n              </div>\n\n              {/* Card 4: Temperature & Dewpoint */}\n              <div className=\"bg-[#0F172A] border border-[#1E293B] rounded-xl p-5 shadow-md hover:border-[#1E293B]/80 transition-colors flex flex-col justify-between h-[150px]\">\n                <div className=\"flex justify-between items-start\">\n                  <span className=\"text-xs font-mono uppercase tracking-wider text-slate-500\">Temperature &amp; Dewpoint</span>\n                  <Thermometer className=\"w-4 h-4 text-[#38BDF8]\" />\n                </div>\n                <div>\n                  <div className=\"flex items-baseline gap-2 mt-1\">\n                    <h4 className=\"font-display text-xl font-bold text-white\">\n                      T: {metar.temperature.tempC}\302\260C <span className=\"text-xs text-slate-400 font-normal\">({metar.temperature.tempF}\302\260F)</span>\n                    </h4>\n                    <span className=\"text-slate-600\">/</span>\n                    <h4 className=\"font-display text-sm font-semibold text-slate-300\">\n                      DP: {metar.temperature.dewpointC}\302\260C\n                    </h4>\n                  </div>\n                  \n                  {/* Dewpoint spread and risk */}\n                  <div className=\"flex items-center gap-2 mt-2\">\n                    <span className=\"text-[10px] font-mono text-slate-400\">\n                      Spread: {metar.temperature.spreadC}\302\260C\n                    </span>\n                    {metar.temperature.fogRisk && (\n                      <span className=\"px-1.5 py-0.5 rounded text-[10px] font-mono font-bold bg-[#F59E0B]/10 text-[#F59E0B] border border-[#F59E0B]/20\">\n                        Fog Risk\n                      </span>\n                    )}\n                  </div>\n                </div>\n              </div>\n\n              {/* Card 5: Clouds */}\n              <div className=\"bg-[#0F172A] border border-[#1E293B] rounded-xl p-5 shadow-md hover:border-[#1E293B]/80 transition-colors flex flex-col justify-between sm:col-span-2 min-h-[150px]\">\n                <div className=\"flex justify-between items-start\">\n                  <span className=\"text-xs font-mono uppercase tracking-wider text-slate-500\">Cloud Layers</span>\n                  <Cloud className=\"w-4 h-4 text-[#38BDF8]\" />\n                </div>\n                <div className=\"mt-3 space-y-2\">\n                  {metar.clouds.map((cl, idx) => {\n                    const isHazard = cl.isCb || cl.isTcu;\n                    return (\n                      <div key={idx} className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-1 border-b border-[#1E293B]/50 pb-1.5 last:border-none last:pb-0\">\n                        <span className=\"text-sm font-mono text-slate-200\">\n                          {cl.coverageText}\n                        </span>\n                        {cl.heightM !== null && (\n                          <span className=\"text-xs text-slate-500 font-mono\">\n                            {cl.heightFt?.toLocaleString()} ft AGL / {cl.heightM?.toLocaleString()} m\n                          </span>\n                        )}\n                        {isHazard && (\n                          <span className=\"self-start sm:self-auto px-1.5 py-0.5 rounded text-[10px] font-mono font-bold bg-[#EF4444]/10 text-[#EF4444] border border-[#EF4444]/20\">\n                            Convective Threat\n                          </span>\n                        )}\n                      </div>\n                    );\n                  })}\n                </div>\n              </div>\n\n              {/* Card 6: Weather Phenomena */}\n              <div className=\"bg-[#0F172A] border border-[#1E293B] rounded-xl p-5 shadow-md hover:border-[#1E293B]/80 transition-colors flex flex-col justify-between h-[150px]\">\n                <div className=\"flex justify-between items-start\">\n                  <span className=\"text-xs font-mono uppercase tracking-wider text-slate-500\">Weather Phenomena</span>\n                  <HelpCircle className=\"w-4 h-4 text-[#38BDF8]\" />\n                </div>\n                <div className=\"space-y-1\">\n                  {metar.weatherPhenomena.map((item, index) => (\n                    <p key={index} className=\"text-sm text-slate-200 font-mono\">\n                      {item}\n                    </p>\n                  ))}\n                </div>\n              </div>\n\n              {/* Card 7: Pressure */}\n              <div className=\"bg-[#0F172A] border border-[#1E293B] rounded-xl p-5 shadow-md hover:border-[#1E293B]/80 transition-colors flex flex-col justify-between h-[150px]\">\n                <div className=\"flex justify-between items-start\">\n                  <span className=\"text-xs font-mono uppercase tracking-wider text-slate-500\">Altimeter (QNH)</span>\n                  <Gauge className=\"w-4 h-4 text-[#38BDF8]\" />\n                </div>\n                <div>\n                  <h4 className=\"font-display text-2xl font-bold text-white mt-1\">\n                    {metar.pressure.hPa} hPa\n                    <span className=\"text-xs text-slate-400 font-normal ml-2\">({metar.pressure.inHg} inHg)</span>\n                  </h4>\n                  <div className=\"flex items-center gap-1.5 mt-1.5 text-xs text-slate-400 font-mono\">\n                    <p>\n                      {metar.pressure.isStandard \n                        ? \'Standard atmospheric pressure\' \n                        : metar.pressure.hPa > 1013 \n                          ? \'High-pressure system\' \n                          : \'Low-pressure system\'}\n                    </p>\n                  </div>\n                </div>\n              </div>\n\n              {/* Card 8: Flight Rules Explanation Badge */}\n              <div className={`sm:col-span-2 border rounded-xl p-5 flex flex-col md:flex-row gap-4 items-start md:items-center justify-between bg-slate-900/40 border-[#1E293B]`}>\n                <div className=\"space-y-1\">\n                  <span className=\"text-xs font-mono uppercase tracking-wider text-slate-500\">Current Rules Threshold</span>\n                  <h4 className={`font-display text-lg font-bold ${metar.flightCategory.colorClass}`}>\n                    {metar.flightCategory.code} Conditions Active\n                  </h4>\n                  <p className=\"text-slate-300 text-xs leading-relaxed max-w-xl\">\n                    {metar.flightCategory.explanation}\n                  </p>\n                </div>\n                <div className={`px-4 py-3.5 rounded-xl border text-center font-display font-black text-2xl tracking-wider w-full md:w-28 ${metar.flightCategory.bgClass} ${metar.flightCategory.colorClass} ${metar.flightCategory.borderClass}`}>\n                  {metar.flightCategory.code}\n                </div>\n              </div>\n\n            </div>\n          </div>\n\n          {/* Section C \342\200\224 TAF DECODER Timeline Forecast & Trend Charts */}\n          <div className=\"space-y-6\">\n            <div>\n              <h3 className=\"font-display text-xl font-bold text-white mb-2 flex items-center gap-2\">\n                <TrendingUp className=\"w-5 h-5 text-[#38BDF8]\" />\n                TAF Trend Analysis &amp; Forecast\n              </h3>\n              <p className=\"text-slate-400 text-xs\">\n                Timeline forecast of incoming weather fronts and cloud bases over the next 24 to 30 hours.\n              </p>\n            </div>\n\n            {/* Horizontal Timeline Scroll */}\n            {taf ? (\n              <div className=\"space-y-4\">\n                <div className=\"flex gap-4 overflow-x-auto pb-4 snap-x select-none\" id=\"taf-timeline-scroll\">\n                  {taf.periods.map((p, index) => (\n                    <div \n                      key={index} \n                      className=\"flex-shrink-0 w-[290px] bg-[#0F172A] border border-[#1E293B] hover:border-[#38BDF8]/40 rounded-xl p-5 snap-start shadow-md flex flex-col justify-between gap-4 transition-colors relative\"\n                    >\n                      {/* Period Label Tag */}\n                      <div className=\"flex justify-between items-start\">\n                        <span className=\"px-2 py-0.5 rounded text-[10px] font-mono font-bold bg-[#38BDF8]/10 text-[#38BDF8] border border-[#38BDF8]/20 uppercase\">\n                          {p.type}\n                        </span>\n                        <span className={`px-2 py-0.5 rounded text-[10px] font-mono font-bold border ${p.flightCategory.bgClass} ${p.flightCategory.colorClass} ${p.flightCategory.borderClass}`}>\n                          {p.flightCategory.code}\n                        </span>\n                      </div>\n\n                      {/* Period Timing */}\n                      <div>\n                        <div className=\"text-xs text-slate-400 font-mono space-y-0.5\">\n                          <p>From: {p.timeStart}</p>\n                          <p>To: {p.timeEnd}</p>\n                        </div>\n                        <p className=\"text-xs font-mono text-slate-500 mt-2 line-clamp-1 truncate select-text bg-[#0A0F1E] p-1.5 rounded\">\n                          {p.rawText}\n                        </p>\n                      </div>\n\n                      {/* Clean Text Summary */}\n                      <p className=\"text-slate-300 text-xs leading-relaxed border-t border-[#1E293B]/50 pt-3\">\n                        {p.summary}\n                      </p>\n                    </div>\n                  ))}\n                </div>\n\n                {/* Trend Charts Section */}\n                <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                  {/* Wind Velocity Trend Chart */}\n                  <div className=\"bg-[#0F172A] border border-[#1E293B] rounded-2xl p-5 shadow-lg\">\n                    <h4 className=\"font-display text-sm font-semibold text-slate-300 mb-4 flex items-center gap-1.5\">\n                      <Wind className=\"w-4 h-4 text-[#38BDF8]\" />\n                      Wind Velocity Trend (Knots)\n                    </h4>\n                    <div className=\"h-60\">\n                      <ResponsiveContainer width=\"100%\" height=\"100%\">\n                        <AreaChart\n                          data={trendChartData}\n                          margin={{ top: 10, right: 10, left: -25, bottom: 0 }}\n                        >\n                          <defs>\n                            <linearGradient id=\"colorWind\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                              <stop offset=\"5%\" stopColor=\"#38BDF8\" stopOpacity={0.2}/>\n                              <stop offset=\"95%\" stopColor=\"#38BDF8\" stopOpacity={0}/>\n                            </linearGradient>\n                            <linearGradient id=\"colorGusts\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                              <stop offset=\"5%\" stopColor=\"#F59E0B\" stopOpacity={0.15}/>\n                              <stop offset=\"95%\" stopColor=\"#F59E0B\" stopOpacity={0}/>\n                            </linearGradient>\n                          </defs>\n                          <CartesianGrid strokeDasharray=\"3 3\" stroke=\"#1E293B\" />\n                          <XAxis dataKey=\"name\" stroke=\"#64748B\" fontSize={10} fontClassName=\"font-mono\" />\n                          <YAxis stroke=\"#64748B\" fontSize={10} fontClassName=\"font-mono\" />\n                          <Tooltip \n                            contentStyle={{ backgroundColor: \'#0F172A\', borderColor: \'#1E293B\', borderRadius: \'8px\' }}\n                            labelStyle={{ color: \'#F8FAFC\', fontFamily: \'monospace\', fontSize: \'12px\' }}\n                            itemStyle={{ fontSize: \'12px\' }}\n                          />\n                          <Legend wrapperStyle={{ fontSize: \'11px\', paddingTop: \'10px\' }} />\n                          <Area type=\"monotone\" dataKey=\"Wind Speed\" stroke=\"#38BDF8\" strokeWidth={2} fillOpacity={1} fill=\"url(#colorWind)\" />\n                          <Area type=\"monotone\" dataKey=\"Wind Gusts\" stroke=\"#F59E0B\" strokeWidth={1.5} strokeDasharray=\"5 5\" fillOpacity={1} fill=\"url(#colorGusts)\" />\n                        </AreaChart>\n                      </ResponsiveContainer>\n                    </div>\n                  </div>\n\n                  {/* Visibility Miles Trend Chart */}\n                  <div className=\"bg-[#0F172A] border border-[#1E293B] rounded-2xl p-5 shadow-lg\">\n                    <h4 className=\"font-display text-sm font-semibold text-slate-300 mb-4 flex items-center gap-1.5\">\n                      <Eye className=\"w-4 h-4 text-[#22C55E]\" />\n                      Forecast Visibility (SM)\n                    </h4>\n                    <div className=\"h-60\">\n                      <ResponsiveContainer width=\"100%\" height=\"100%\">\n                        <LineChart\n                          data={trendChartData}\n                          margin={{ top: 10, right: 10, left: -25, bottom: 0 }}\n                        >\n                          <CartesianGrid strokeDasharray=\"3 3\" stroke=\"#1E293B\" />\n                          <XAxis dataKey=\"name\" stroke=\"#64748B\" fontSize={10} fontClassName=\"font-mono\" />\n                          <YAxis stroke=\"#64748B\" fontSize={10} domain={[0, 10]} fontClassName=\"font-mono\" />\n                          <Tooltip \n                            contentStyle={{ backgroundColor: \'#0F172A\', borderColor: \'#1E293B\', borderRadius: \'8px\' }}\n                            labelStyle={{ color: \'#F8FAFC\', fontFamily: \'monospace\', fontSize: \'12px\' }}\n                            itemStyle={{ fontSize: \'12px\' }}\n                          />\n                          <Legend wrapperStyle={{ fontSize: \'11px\', paddingTop: \'10px\' }} />\n                          <Line type=\"monotone\" dataKey=\"Visibility (SM)\" stroke=\"#22C55E\" strokeWidth={2.5} activeDot={{ r: 6 }} />\n                        </LineChart>\n                      </ResponsiveContainer>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            ) : (\n              <div className=\"bg-[#0F172A] border border-[#1E293B] rounded-xl p-6 text-center text-slate-500 font-mono text-xs\">\n                No TAF weather forecast trend data is available for {metar.icao}. Trend charts require active Terminal Aerodrome Forecast reports.\n              </div>\n            )}\n          </div>\n        </div>\n\n        {/* Right Column: Section D \342\200\224 Pilot Notes Static Sidebar Panel */}\n        <div className=\"space-y-6\">\n          <div className=\"bg-[#0F172A] border border-[#1E293B] rounded-2xl p-6 shadow-xl space-y-6 sticky top-24\">\n            \n            {/* Sidebar Title */}\n            <div>\n              <h3 className=\"font-display text-lg font-bold text-slate-100 flex items-center gap-2\">\n                <BookOpen className=\"w-5 h-5 text-[#38BDF8]\" />\n                Pilot Reference Card\n              </h3>\n              <p className=\"text-xs font-mono text-slate-500 uppercase tracking-wider mt-0.5\">\n                Educational Airspace Notes\n              </p>\n            </div>\n\n            {/* Paragraph 1: What is a METAR */}\n            <div className=\"space-y-2 border-b border-[#1E293B] pb-4\">\n              <h4 className=\"text-xs font-mono font-bold text-[#38BDF8] uppercase tracking-wide\">\n                What is a METAR?\n              </h4>\n              <p className=\"text-slate-300 text-xs leading-relaxed\">\n                A METAR (Meteorological Aerodrome Report) is an aviation weather report issued hourly. It outlines real-time winds, visibility, weather systems, and clouds. It serves as the primary observation source for pilots during pre-flight.\n              </p>\n            </div>\n\n            {/* Paragraph 2: Fog Formation Rule of Thumb */}\n            <div className=\"space-y-2 border-b border-[#1E293B] pb-4\">\n              <h4 className=\"text-xs font-mono font-bold text-[#38BDF8] uppercase tracking-wide\">\n                Dewpoint Spread &amp; Fog\n              </h4>\n              <p className=\"text-slate-300 text-xs leading-relaxed\">\n                When the temperature and dewpoint spread is within 3 degrees Celsius (5.4 degrees Fahrenheit), the relative humidity reaches near-saturation. Under calm or light winds, there is a high probability of fog or low-ceiling stratus cloud formation. Avoid flight patterns without instrument ratings.\n              </p>\n            </div>\n\n            {/* Paragraph 3: VFR minimums reminder */}\n            <div className=\"space-y-2 border-b border-[#1E293B] pb-4\">\n              <h4 className=\"text-xs font-mono font-bold text-[#38BDF8] uppercase tracking-wide\">\n                VFR Flight Minimums\n              </h4>\n              <p className=\"text-slate-300 text-xs leading-relaxed\">\n                Under standard Class E airspace regulations, basic visual flight rules (VFR) require at least 3 statute miles of flight visibility and a cloud ceiling of no less than 1,000 feet above the surface (AGL). Remember that safe pilots maintain buffers above regulatory minimums.\n              </p>\n            </div>\n\n            {/* Paragraph 4: AIP placeholder links */}\n            <div className=\"space-y-2\">\n              <h4 className=\"text-xs font-mono font-bold text-[#38BDF8] uppercase tracking-wide\">\n                Aviation Publications (AIP)\n              </h4>\n              <p className=\"text-slate-300 text-xs leading-relaxed\">\n                For complete runway geometry, navigation frequencies, and localized noise abatement charts, verify the official Aeronautical Information Publication (AIP).\n              </p>\n              <div className=\"pt-2\">\n                <a \n                  href=\"https://www.faa.gov/air_traffic/publications/atpubs/aip_html/index.html\" \n                  target=\"_blank\" \n                  rel=\"noreferrer\" \n                  className=\"inline-flex items-center gap-1 text-xs text-[#38BDF8] hover:underline font-mono\"\n                >\n                  FAA AIP Directory &rarr;\n                </a>\n              </div>\n            </div>\n\n          </div>\n        </div>\n\n      </div>\n\n    </div>\n  );\n}\n"
    }
