    web_documents {
      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEiX5rNQgtwOFYOLhE8DQcfkeELtIN6vq8Lv2XxGzWmY6YCMaAWRwj2C-vbunzaWCVqAaKQLFrzvgCnvdlnSG17RK6W-grPRNw_jKq4gPaSfB41qXHqW0JAtiTho34gh5BhOWpY8jXO-0CUumYg9GGnnekYaAEc7wAdzvUDx52yIawpI3v0LwYDfohFxvJu9NFkmlWtYoBf2jKXRN7Pvnil8fQdZTFTJtJeXUCnQWM9Huo-ILlHN7zp5qQLXdUS3n5ZTSe6RnLE"
